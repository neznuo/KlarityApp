# Klarity Backend – Environment Configuration Example
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# ─── Storage ──────────────────────────────────────────────────────────────────
BASE_STORAGE_DIR=~/Documents/AI-Meetings

# ─── Transcription ────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key_here
DEFAULT_TRANSCRIPTION_PROVIDER=elevenlabs

# ─── LLM Providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
OLLAMA_ENDPOINT=http://localhost:11434
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3

# ─── Speaker Matching ─────────────────────────────────────────────────────────
SPEAKER_SUGGEST_THRESHOLD=0.75
SPEAKER_AUTO_ASSIGN_THRESHOLD=0.90
SPEAKER_DUPLICATE_THRESHOLD=0.82

# ─── Server ───────────────────────────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8765
LOG_LEVEL=INFO
