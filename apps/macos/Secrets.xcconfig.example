// Google: Create an OAuth 2.0 Client ID (iOS type) in Google Cloud Console.
//   https://console.cloud.google.com/apis/credentials
//   The reverse client ID is: com.googleusercontent.apps.<CLIENT_ID_PREFIX>
//   where CLIENT_ID_PREFIX is everything before ".apps.googleusercontent.com"
// Microsoft: Register an app in Azure Portal → App registrations.
//   https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade

GOOGLE_CLIENT_ID = 1072184484443-82lhf4egmuc2rs7p45gc45cgje92q6us.apps.googleusercontent.com
GOOGLE_REVERSE_CLIENT_ID = com.googleusercontent.apps.1072184484443-82lhf4egmuc2rs7p45gc45cgje92q6us
MICROSOFT_CLIENT_ID = YOUR_MICROSOFT_CLIENT_ID