<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Klarity</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>KlarityApp</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>14.0</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSMicrophoneUsageDescription</key>
	<string>KlarityApp records meeting audio from your microphone.</string>
	<!-- Required for Core Audio Process Tap (system audio capture). Does not appear
	     in Xcode's Info.plist dropdown — must be added manually. Without this key
	     macOS will silently deliver silence from the tap even if the user approves. -->
	<key>NSAudioCaptureUsageDescription</key>
	<string>KlarityApp captures system audio to record meeting participants.</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSScreenCaptureUsageDescription</key>
	<string>KlarityApp needs Screen Recording permission to capture system audio (Zoom, Meets, etc). No video frames are ever recorded.</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.klarity.oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>klarity</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.googleusercontent.apps</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.1072184484443-ot4bvnhs4dshgvh61v4g87u99mqmk5kn</string>
			</array>
		</dict>
	</array>
	<key>KlarityGoogleClientID</key>
	<string>1072184484443-ot4bvnhs4dshgvh61v4g87u99mqmk5kn.apps.googleusercontent.com</string>
